{
  "name": "@llmscope/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "llmscope-web": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  }
}
